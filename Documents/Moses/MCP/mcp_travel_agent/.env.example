# Шаблон переменных окружения. Скопируй в .env и подставь свои значения.

# === Провайдер LLM ===
# По умолчанию — локальный Ollama с моделью Qwen 2.5 7B.
# Ollama не имеет региональных ограничений и работает в РФ без VPN.
# Чтобы переключиться на другой провайдер — см. варианты ниже.

# Ollama (по умолчанию, рекомендуется для РФ):
#   1) Установи: https://ollama.com/download
#   2) Скачай модель: ollama pull qwen2.5:14b
#   3) Убедись, что сервис запущен: ollama serve
OPENAI_BASE_URL=http://127.0.0.1:11434/v1
OPENAI_MODEL=qwen2.5:14b
OPENAI_API_KEY=ollama

# OpenAI cloud (если есть VPN/прокси в разрешённый регион):
#   Закомментируй OPENAI_BASE_URL и OPENAI_MODEL выше, подставь ключ:
# OPENAI_BASE_URL=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...

# OpenRouter (облачные LLM с оплатой по токенам):
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=qwen/qwen-2.5-72b-instruct
# OPENAI_API_KEY=sk-or-...

# === Таймаут на вызовы MCP, секунды ===
MCP_TIMEOUT=30

# === Foursquare (не подключаем в MVP) ===
# Если понадобится:
# 1) раскомментируй строку ниже и вставь свой API Key с foursquare.com/developers;
# 2) включи клиент в agent/openai_agent.py по инструкции из README.md.
# FOURSQUARE_API_KEY=
