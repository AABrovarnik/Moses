# Шаблон переменных окружения. Скопируй в .env и подставь свои значения.

# Ключ OpenAI (https://platform.openai.com → API keys)
OPENAI_API_KEY=

# Модель OpenAI. Рекомендую gpt-4o-mini для tool-use.
OPENAI_MODEL=gpt-4o-mini

# Таймаут на вызовы MCP, секунды
MCP_TIMEOUT=30

# Foursquare — не подключаем в MVP. Если понадобится:
# 1) раскомментируй строку ниже и вставь свой API Key с foursquare.com/developers;
# 2) включи клиент в agent/openai_agent.py по инструкции из README.md.
# FOURSQUARE_API_KEY=
